CREATE TABLE ml_experiment_result (

    -- Identidade do experimento
    experiment_id TEXT PRIMARY KEY,

    -- Contexto governança
    pipeline_version INTEGER NOT NULL,
    dataset_name TEXT NOT NULL,
    vendor TEXT NOT NULL,
    problem_type TEXT NOT NULL,
    strategy_name TEXT NOT NULL,

    -- Resultado científico
    metric_name TEXT NOT NULL,
    metric_value DOUBLE PRECISION NOT NULL,
    decision TEXT NOT NULL CHECK (
        decision IN ('APPROVED', 'REJECTED', 'TERMINATED')
    ),
    reason TEXT NOT NULL,

    -- Modelo aprovado (pode ser nulo)
    model_name TEXT NULL,

    -- Relatório completo do treino
    training_report JSONB NOT NULL,

    -- Auditoria mínima
    created_at TIMESTAMP NOT NULL DEFAULT NOW()
);




    def get_runs(self, dataset_name: str):

        conn = self.connector.get_conn()
        cursor = conn.cursor()

        query = """
        SELECT
            pm.pipeline_version,
            ml.model_name,
            ml.metric_name,
            ml.metric_value,
            pm.duration_ms
        FROM pipeline_metrics pm

        LEFT JOIN ml_experiment_result ml
            ON pm.trace_id = ml.trace_id

        WHERE pm.dataset_name = %s
        ORDER BY pm.pipeline_version DESC
        LIMIT 20
        """

        cursor.execute(query, (dataset_name,))
        rows = cursor.fetchall()

        cursor.close()
        conn.close()

        results = []

        for row in rows:
            results.append({
                "pipeline_version": row[0],
                "model_name": row[1],
                "metric_name": row[2],
                "metric_value": row[3],
                "duration_ms": row[4]
            })

        return results



